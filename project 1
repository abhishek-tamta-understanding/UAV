class IoTSensorNode:
    """
    Real-world IoT sensor node simulator.

    Ek node = Field mein ek box
    jisme sab sensors hain +
    WiFi/LoRaWAN module +
    Solar panel + Battery
    """

    def __init__(self, node_id, estate_name,
                 lon, lat, estate_ha):
        self.node_id      = node_id
        self.estate_name  = estate_name
        self.lon          = lon
        self.lat          = lat
        self.estate_ha    = estate_ha

        # Node status
        self.battery_pct  = random.uniform(70, 100)
        self.solar_watts  = random.uniform(0, 5)
        self.signal_rssi  = random.randint(-80, -40)
        self.uptime_hrs   = random.randint(0, 720)
        self.data_buffer  = deque(maxlen=288)  # 24hr @ 5min
        self.alerts       = []
        self.last_read    = None

        # Calibration offsets (real sensors drift!)
        self.temp_offset  = random.uniform(-0.5, 0.5)
        self.hum_offset   = random.uniform(-2, 2)

        # Season/time context (simulated)
        self.current_hour = random.randint(6, 18)

    def read_sensors(self, timestamp=None):
        """
        Sabhi sensors se data padhna.

        CONCEPT: Sensor data random nahi
        — realistic physics-based simulation!
        Temperature diurnal cycle follow
        karta hai, rain events cluster hote
        hain, etc.
        """
        if timestamp is None:
            timestamp = datetime.now()

        hour = timestamp.hour

        # --------------------------------
        # TEMPERATURE — Diurnal cycle
        # Morning cool, afternoon hot
        # --------------------------------
        # April in Assam: avg 28°C
        base_temp = 27.0
        diurnal   = 5 * math.sin(
            math.pi * (hour - 6) / 12)
        temp      = (base_temp + diurnal +
                     self.temp_offset +
                     random.gauss(0, 0.3))
        temp      = round(
            max(15, min(40, temp)), 1)

        # --------------------------------
        # HUMIDITY — Inverse of temperature
        # --------------------------------
        base_hum  = 75.0
        hum_diurnal = -10 * math.sin(
            math.pi * (hour - 6) / 12)
        humidity  = (base_hum + hum_diurnal +
                     self.hum_offset +
                     random.gauss(0, 2))
        humidity  = round(
            max(30, min(98, humidity)), 1)

        # --------------------------------
        # RAINFALL — Occasional events
        # --------------------------------
        # 20% chance of rain in April
        if random.random() < 0.05:
            rainfall = np.random.exponential(8)
        else:
            rainfall = 0.0
        rainfall = round(
            max(0, min(50, rainfall)), 1)

        # --------------------------------
        # WIND — Higher during day
        # --------------------------------
        wind_base = 6 + 4 * math.sin(
            math.pi * (hour - 9) / 9) \
            if 9 <= hour <= 18 else 3
        wind_speed = round(
            max(0, wind_base +
                random.gauss(0, 1.5)), 1)
        wind_dir   = round(
            random.uniform(0, 360), 0)

        # --------------------------------
        # SOIL MOISTURE
        # --------------------------------
        soil_moisture = round(
            random.uniform(35, 70), 1)
        soil_temp     = round(
            temp - random.uniform(2, 5), 1)

        # --------------------------------
        # LEAF WETNESS
        # High after rain or early morning
        # --------------------------------
        if rainfall > 0 or hour < 9:
            leaf_wetness = random.uniform(60, 100)
        else:
            leaf_wetness = random.uniform(10, 40)
        leaf_wetness = round(leaf_wetness, 1)

        # --------------------------------
        # LIGHT
        # --------------------------------
        if 6 <= hour <= 18:
            light = round(
                1000 * math.sin(
                    math.pi * (hour - 6) / 12) +
                random.gauss(0, 50), 0)
        else:
            light = 0
        light = max(0, light)
        uv    = round(light / 200, 1)

        # --------------------------------
        # BATTERY & SOLAR UPDATE
        # --------------------------------
        self.solar_watts = round(
            5 * math.sin(
                math.pi * (hour - 6) / 12)
            if 6 <= hour <= 18 else 0, 2)
        self.battery_pct = min(100,
            self.battery_pct +
            self.solar_watts * 0.1 -
            random.uniform(0.01, 0.05))
        self.battery_pct = round(
            self.battery_pct, 1)

        reading = {
            'timestamp':      timestamp.isoformat(),
            'node_id':        self.node_id,
            'estate':         self.estate_name,
            'lon':            self.lon,
            'lat':            self.lat,
            'temperature':    temp,
            'humidity':       humidity,
            'rainfall_mm':    rainfall,
            'wind_speed':     wind_speed,
            'wind_dir':       wind_dir,
            'soil_moisture':  soil_moisture,
            'soil_temp':      soil_temp,
            'leaf_wetness':   leaf_wetness,
            'light_lux':      light,
            'uv_index':       uv,
            'battery_pct':    self.battery_pct,
            'solar_watts':    self.solar_watts,
            'signal_rssi':    self.signal_rssi,
        }

        self.data_buffer.append(reading)
        self.last_read = timestamp
        return reading

    def get_7day_rainfall(self):
        """Buffer se last 7 days ki rainfall"""
        if not self.data_buffer:
            return random.uniform(5, 30)
        return sum(r['rainfall_mm']
                   for r in self.data_buffer)

    def check_alerts(self, reading):
        """
        CONCEPT: Edge computing!
        Node khud check karta hai
        thresholds — cloud pe load
        nahi bhejta!
        """
        alerts = []

        if reading['temperature'] > 35:
            alerts.append({
                'type':     'HEAT_STRESS',
                'severity': 'HIGH',
                'value':    reading['temperature'],
                'msg':      f"Temperature {reading['temperature']}°C - Heat stress risk!"
            })

        if reading['humidity'] < 45:
            alerts.append({
                'type':     'LOW_HUMIDITY',
                'severity': 'MEDIUM',
                'value':    reading['humidity'],
                'msg':      f"Humidity {reading['humidity']}% - Mite risk!"
            })

        if reading['rainfall_mm'] > 20:
            alerts.append({
                'type':     'HEAVY_RAIN',
                'severity': 'LOW',
                'value':    reading['rainfall_mm'],
                'msg':      f"Rainfall {reading['rainfall_mm']}mm - Watch for fungal disease!"
            })

        if reading['battery_pct'] < 20:
            alerts.append({
                'type':     'LOW_BATTERY',
                'severity': 'MEDIUM',
                'value':    reading['battery_pct'],
                'msg':      f"Battery {reading['battery_pct']}% - Needs attention!"
            })

        if reading['leaf_wetness'] > 80:
            alerts.append({
                'type':     'LEAF_WET',
                'severity': 'MEDIUM',
                'value':    reading['leaf_wetness'],
                'msg':      "High leaf wetness - Helopeltis risk!"
            })

        self.alerts.extend(alerts)
        return alerts


