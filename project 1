# ============================================
# STEP 2: Synthetic estates generate karo
# 
# CONCEPT: Hum 1076 individual estates
# manually enter nahi kar sakte.
# Toh numpy se realistic random distribution
# banate hain — real data jaisa!
#
# np.random.normal(center, spread, count)
# = center ke aaspaas normally 
#   distributed points
# ============================================

np.random.seed(42)  # Reproducibility ke liye

all_estates = []      # Coordinates
estate_districts = [] # Har estate ka district
estate_sizes = []     # Har estate ka size (ha)

print("Estates generate ho rahe hain...")
print("=" * 45)

for district, info in assam_districts.items():
    lon_center, lat_center = info['center']
    n_estates = info['estates']
    total_ha = info['hectares']
    
    # Estates ko district center ke
    # aaspaas scatter karo
    # 0.3 degree ≈ 30km spread
    lons = np.random.normal(
        lon_center, 0.3, n_estates)
    lats = np.random.normal(
        lat_center, 0.2, n_estates)
    
    # Har estate ka size
    # (total hectares / estates = average)
    avg_size = total_ha / n_estates
    sizes = np.random.normal(
        avg_size, avg_size*0.3, n_estates)
    sizes = np.abs(sizes)  # Negative nahi ho
    
    for lon, lat, size in zip(lons, lats, sizes):
        all_estates.append([lon, lat])
        estate_districts.append(district)
        estate_sizes.append(size)
    
    print(f"{district:12}: "
          f"{n_estates} estates, "
          f"{total_ha:,} hectares")

all_estates = np.array(all_estates)
estate_sizes = np.array(estate_sizes)

print(f"\nTotal estates generated: "
      f"{len(all_estates)}")
print(f"Total area: "
      f"{estate_sizes.sum():,.0f} hectares")

# ============================================
# STEP 3: GPS → Meters Convert
#
# CONCEPT: Clustering distance mein
# kaam karta hai.
# GPS degrees mein hai — convert karo!
# ============================================

def gps_to_meters(coords, 
                  lon0=92.0, lat0=24.0):
    """
    Sabhi GPS coordinates ko
    meters mein convert karo.
    Reference point: SW corner of Assam
    """
    R = 6371000
    coords_m = []
    
    for lon, lat in coords:
        x = R * math.radians(
            lon - lon0) * math.cos(
            math.radians(lat0))
        y = R * math.radians(lat - lat0)
        coords_m.append([x, y])
    
    return np.array(coords_m)

coords_meters = gps_to_meters(all_estates)

print(f"\nCoordinate range:")
print(f"East-West:   "
      f"{coords_meters[:,0].min()/1000:.0f} to "
      f"{coords_meters[:,0].max()/1000:.0f} km")
print(f"North-South: "
      f"{coords_meters[:,1].min()/1000:.0f} to "
      f"{coords_meters[:,1].max()/1000:.0f} km")

# ============================================
# STEP 4: Optimal K Dhundo
#
# CONCEPT: Silhouette Score
# 
# Score = -1 to +1
# +1 = Perfect clustering
#  0 = Overlapping clusters  
# -1 = Wrong clustering
#
# Hum 2 se 15 clusters try karenge
# aur best score wala k choose karenge
# ============================================

print("\nOptimal clusters dhund rahe hain...")
print("(Silhouette Score calculate ho raha hai)")

k_range = range(2, 12)
silhouette_scores = []

# Sample use karo — 1076 pe slow hoga
sample_idx = np.random.choice(
    len(coords_meters), 300, replace=False)
sample_coords = coords_meters[sample_idx]

for k in k_range:
    kmeans_test = KMeans(
        n_clusters=k, 
        random_state=42,
        n_init=10
    )
    labels_test = kmeans_test.fit_predict(
        sample_coords)
    score = silhouette_score(
        sample_coords, labels_test)
    silhouette_scores.append(score)
    print(f"  k={k:2d} clusters: "
          f"Score = {score:.4f}")

best_k = k_range.start + \
         silhouette_scores.index(
             max(silhouette_scores))
print(f"\nBest k = {best_k} "
      f"(Score: {max(silhouette_scores):.4f})")

# ============================================
# STEP 5: Final Clustering
# ============================================

kmeans_final = KMeans(
    n_clusters=best_k,
    random_state=42,
    n_init=10
)
labels = kmeans_final.fit_predict(
    coords_meters)
centers = kmeans_final.cluster_centers_

# ============================================
# STEP 6: Drone Operations Calculate Karo
#
# CONCEPT: Har cluster ke liye
# kitne drone sorties chahiye?
#
# DJI T40 (modern agri drone):
# Coverage: ~40 hectares/hour
# Battery: ~15 min per charge
# Per sortie: ~10 hectares
# ============================================

DRONE_COVERAGE_PER_SORTIE = 10  # hectares
DRONE_SPEED = 7  # m/s
SPRAY_WIDTH = 5  # meters

print("\n" + "="*50)
print("DRONE OPERATION ANALYSIS:")
print("="*50)

cluster_info = []
for i in range(best_k):
    cluster_mask = labels == i
    cluster_estates = \
        all_estates[cluster_mask]
    cluster_sizes = \
        estate_sizes[cluster_mask]
    
    n_estates_cluster = \
        cluster_mask.sum()
    total_ha = cluster_sizes.sum()
    sorties_needed = math.ceil(
        total_ha / DRONE_COVERAGE_PER_SORTIE)
    
    # Supply point (cluster center)
    # Meters → GPS wapas convert
    center_m = centers[i]
    center_lon = 92.0 + center_m[0] / (
        6371000 * math.cos(
            math.radians(24.0)) * 
        math.pi/180)
    center_lat = 24.0 + center_m[1] / (
        6371000 * math.pi/180)
    
    cluster_info.append({
        'id': i+1,
        'estates': n_estates_cluster,
        'hectares': total_ha,
        'sorties': sorties_needed,
        'center_gps': (center_lon, center_lat)
    })
    
    print(f"\nZone {i+1}:")
    print(f"  Estates:  {n_estates_cluster}")
    print(f"  Area:     {total_ha:,.0f} ha")
    print(f"  Sorties:  {sorties_needed} drone flights")
    print(f"  Supply Point: "
          f"({center_lon:.4f}°E, "
          f"{center_lat:.4f}°N)")

# ============================================
# STEP 7: Visualization
# ============================================

fig, axes = plt.subplots(1, 2, 
                          figsize=(16, 7))

# Plot 1: Clustered estates
colors = plt.cm.Set1(
    np.linspace(0, 1, best_k))

