# METHOD 2: GREEDY — NEAREST NEIGHBOR
#
# CONCEPT: Hamesha nearest unvisited
# estate ko visit karo.
# "Common sense" algorithm!
#
# Limitation: Locally good,
# globally not optimal!
# -------------------------------------------

def greedy_route(start, dist_matrix, n):
    """
    Nearest neighbor heuristic.
    Har step pe nearest unvisited jaao.
    """
    visited = [False] * n
    route = [start]
    visited[start] = True

    for _ in range(n - 1):
        current = route[-1]
        nearest = None
        nearest_dist = float('inf')

        for j in range(n):
            if not visited[j]:
                d = dist_matrix[current][j]
                if d < nearest_dist:
                    nearest_dist = d
                    nearest = j

        route.append(nearest)
        visited[nearest] = True

    return route

