            s=200, zorder=7,
            label='Tocklai (TRA)')
ax1.annotate('Tocklai\nResearch\nStation',
             xy=(94.21, 26.75),
             xytext=(10, 10),
             textcoords='offset points',
             fontsize=8, fontweight='bold')

ax1.set_title(
    f'Assam Tea Estates — {best_k} Drone Zones\n'
    f'1,076 estates | 341,049 hectares',
    fontweight='bold')
ax1.set_xlabel('Longitude (°E)')
ax1.set_ylabel('Latitude (°N)')
ax1.legend(fontsize=8, 
           loc='lower left')
ax1.grid(True, alpha=0.3)

# Plot 2: Zone-wise stats
ax2 = axes[1]
zone_names = [f'Zone {c["id"]}' 
              for c in cluster_info]
zone_estates = [c['estates'] 
                for c in cluster_info]
zone_sorties = [c['sorties'] 
                for c in cluster_info]

x = np.arange(len(zone_names))
width = 0.35

bars1 = ax2.bar(x - width/2, 
                zone_estates,
                width, 
                label='Estates',
                color=[colors[i] 
                       for i in range(best_k)],
                alpha=0.8)
ax2_twin = ax2.twinx()
bars2 = ax2_twin.bar(x + width/2,
                     zone_sorties,
                     width,
                     label='Drone Sorties',
                     color=[colors[i] 
                            for i in range(best_k)],
                     alpha=0.4,
                     hatch='//')

ax2.set_xlabel('Drone Zone')
ax2.set_ylabel('Number of Estates', 
               color='black')
ax2_twin.set_ylabel('Drone Sorties Needed',
                    color='gray')
ax2.set_xticks(x)
ax2.set_xticklabels(zone_names)
ax2.set_title(
    'Zone-wise: Estates vs Drone Sorties',
    fontweight='bold')

lines1, labels1 = ax2.get_legend_handles_labels()
lines2, labels2 = ax2_twin.get_legend_handles_labels()
ax2.legend(lines1 + lines2, 
           labels1 + labels2,
           loc='upper right')

ax2.grid(True, alpha=0.3, axis='y')
plt.tight_layout()
plt.show()

