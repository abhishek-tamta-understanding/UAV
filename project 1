# -------------------------------------------
# METHOD 3: GENETIC ALGORITHM
#
# CONCEPT:
# 1. Population = 50 random routes
# 2. Fitness = 1/distance (shorter = better)
# 3. Selection = Best routes choose karo
# 4. Crossover = Do routes combine karo
# 5. Mutation = Random swap karo
# 6. Repeat 200 generations
#
# Yahi paper ka GA component hai!
# -------------------------------------------

def genetic_algorithm(
    dist_matrix, n_estates,
    pop_size=50,      # 50 routes ek saath
    generations=200,  # 200 rounds
    mutation_rate=0.02):
    """
    GA for TSP — Paper ka Section 2.3.1

    Parameters:
    pop_size   = kitni routes ek saath
    generations = kitni baar evolve karo
    mutation_rate = kitni baar random change
    """

    indices = list(range(1, n_estates + 1))

    # INITIALIZATION
    # Concept: Random se shuru karo
    # Diversity chahiye starting mein!
    population = []
    for _ in range(pop_size):
        route = [0] + random.sample(
            indices, len(indices))
        population.append(route)

    best_route = None
    best_distance = float('inf')
    history = []  # Convergence track karne ke liye

    for gen in range(generations):

        # FITNESS CALCULATE KARO
        # Concept: Short route = High fitness
        # fitness = 1/distance
        # (Zyada fitness = better individual)
        fitness = []
        for route in population:
            d = route_distance(
                route, dist_matrix)
            fitness.append(1.0 / d)

            # Best route track karo
            if d < best_distance:
                best_distance = d
                best_route = route.copy()

        history.append(best_distance)

        # SELECTION
        # Concept: Roulette wheel selection
        # Better routes ko zyada chance!
        total_fitness = sum(fitness)
        probs = [f/total_fitness
                 for f in fitness]

        # NEW POPULATION BANAO
        new_population = []

        # Elitism: Best 2 routes
        # directly next gen mein
        # Concept: Achhe genes preserve karo!
        sorted_pop = sorted(
            zip(fitness, population),
            reverse=True
        )
        new_population.extend(
            [r for _, r in sorted_pop[:2]])

        while len(new_population) < pop_size:

            # SELECTION: 2 parents chuno
            parent1 = population[
                np.random.choice(
                    len(population), p=probs)]
            parent2 = population[
                np.random.choice(
                    len(population), p=probs)]

            # CROSSOVER (OX - Order Crossover)
            # Concept: Parent1 ka ek hissa lo
            # Baaki Parent2 se fill karo
            # Order preserve karo!
            #
            # Parent1: [0,1,2,3,4,5,6,7]
            # Parent2: [0,5,3,1,7,2,4,6]
            # Cut: [2:5]
            # Child:  [0,?,3,4,5,?,?,?]
            #         (P2 se fill: 1,7,2,6)
            # Child:  [0,1,3,4,5,7,2,6]

            size = len(parent1)
            # Supply point (0) fix hai
            p1 = parent1[1:]
            p2 = parent2[1:]

            start = random.randint(
                0, len(p1)-2)
            end = random.randint(
                start+1, len(p1)-1)

            # P1 ka segment
            child = [None] * len(p1)
            child[start:end] = p1[start:end]

            # P2 se remaining fill karo
            p2_remaining = [
                x for x in p2
                if x not in child]
            j = 0
            for i in range(len(child)):
                if child[i] is None:
                    child[i] = p2_remaining[j]
                    j += 1

            child = [0] + child

            # MUTATION
            # Concept: Random 2 estates swap karo
            # Diversity maintain karo!
            # Prevent premature convergence!
            if random.random() < mutation_rate:
                i = random.randint(1, size-2)
                j = random.randint(1, size-2)
                child[i], child[j] = \
                    child[j], child[i]

            new_population.append(child)

        population = new_population

    return best_route, best_distance, history

