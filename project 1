def euclidean_distance(p1, p2):
    """
    Concept: Seedhi line distance
    Pythagoras theorem!
    d = √((x2-x1)² + (y2-y1)²)
    """
    return math.sqrt(
        (p1['x'] - p2['x'])**2 +
        (p1['y'] - p2['y'])**2
    )

