# ============================================

def gps_to_meters(coords, 
                  lon0=92.0, lat0=24.0):
    """
    Sabhi GPS coordinates ko
    meters mein convert karo.
    Reference point: SW corner of Assam
    """
    R = 6371000
    coords_m = []
    
    for lon, lat in coords:
        x = R * math.radians(
            lon - lon0) * math.cos(
            math.radians(lat0))
        y = R * math.radians(lat - lat0)
        coords_m.append([x, y])
    
    return np.array(coords_m)

