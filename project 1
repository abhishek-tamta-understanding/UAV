# ============================================
# STEP 5: Data Collection Simulation
#
# CONCEPT: Real system mein MQTT broker
# hoga (Mosquitto/HiveMQ).
# Hum queue se simulate karte hain!
#
# MQTT = Message Queuing Telemetry
# Transport — IoT ka standard protocol
#
# Publisher = Sensor node
# Subscriber = ML inference server
# Broker = Message relay (like post office)
# ============================================

class MQTTBrokerSimulator:
    """
    Simulates MQTT broker behavior.

    Topics:
    tocklai/estates/{estate_id}/sensors
    tocklai/estates/{estate_id}/alerts
    tocklai/system/drone/dispatch
    """

    def __init__(self):
        self.topics   = {}
        self.messages = queue.Queue()
        self.log      = []

    def publish(self, topic, payload):
        """Sensor se data publish karo"""
        msg = {
            'topic':     topic,
            'payload':   payload,
            'timestamp': datetime.now().isoformat(),
            'qos':       1  # At least once delivery
        }
        self.messages.put(msg)
        self.log.append(msg)

    def subscribe(self, topic):
        """Latest message padhna"""
        if not self.messages.empty():
            return self.messages.get()
        return None

    def get_all_messages(self):
        """Saare pending messages"""
        msgs = []
        while not self.messages.empty():
            msgs.append(self.messages.get())
        return msgs


class EdgeGateway:
    """
    CONCEPT: Edge Computing!

    Gateway = Raspberry Pi jaisa device
    Estate ke paas hi hota hai.
    Cloud pe bhejne se pehle:
    - Data validate karo
    - Compress karo
    - Local alerts check karo
    - Failed readings handle karo

    Isse LATENCY kam hoti hai!
    Cloud bandwidth bachti hai!
    """

    def __init__(self, gateway_id,
                 estates_covered):
        self.gateway_id = gateway_id
        self.estates    = estates_covered
        self.data_cache = {}
        self.errors     = 0
        self.processed  = 0

    def process_reading(self, reading):
        """
        Edge processing pipeline:
        1. Validate data ranges
        2. Detect sensor errors
        3. Interpolate missing values
        4. Compress for cloud
        """
        processed = reading.copy()

        # Validation
        if not (15 <= processed['temperature'] <= 40):
            processed['temperature_flag'] = 'SUSPECT'
            self.errors += 1

        if not (0 <= processed['humidity'] <= 100):
            processed['humidity'] = \
                max(0, min(100, processed['humidity']))
            processed['humidity_flag'] = 'CORRECTED'

        # Feature engineering at edge
        processed['heat_humidity_index'] = round(
            processed['temperature'] +
            0.33 * (processed['humidity'] / 100 * 6.105 *
                    math.exp(17.27 * processed['temperature'] /
                             (237.7 + processed['temperature'])))
            - 4.0, 2)

        processed['processed_by'] = self.gateway_id
        self.processed += 1
        return processed


