class MLInferenceServer:
    """
    Cloud-based ML inference.
    Receives IoT data → Returns prediction.
    """

    def __init__(self, classifier, regressor,
                 label_encoder):
        self.clf = classifier
        self.reg = regressor
        self.le  = label_encoder
        self.predictions = []
        self.inference_count = 0

    def predict(self, sensor_data,
                flush_stage=2,
                prev_pest_count=3,
                days_since_spray=10):
        """
        REST API endpoint simulation:
        POST /api/v1/predict

        Input: sensor reading JSON
        Output: prediction JSON
        """
        month = datetime.fromisoformat(
            sensor_data['timestamp']).month

        X = np.array([[
            month,
            sensor_data['temperature'],
            sensor_data['humidity'],
            sensor_data.get('rainfall_mm', 0) * 7,
            flush_stage,
            prev_pest_count,
            days_since_spray,
            150,   # elevation estimate
            sensor_data['wind_speed']
        ]])

        # Inference
        pest_idx  = self.clf.predict(X)[0]
        pest_name = self.le.inverse_transform(
            [pest_idx])[0]
        pest_prob = self.clf.predict_proba(X)[0]
        severity  = float(
            self.reg.predict(X)[0])
        severity  = round(
            max(0, min(10, severity)), 1)
        confidence = float(
            max(pest_prob)) * 100

        # Action recommendation
        if severity >= 7:
            action   = 'DISPATCH_DRONE_IMMEDIATE'
            priority = 'P1_CRITICAL'
            color    = '#E74C3C'
        elif severity >= 4:
            action   = 'SCHEDULE_DRONE_48H'
            priority = 'P2_HIGH'
            color    = '#F39C12'
        elif severity >= 2:
            action   = 'MONITOR_CLOSELY'
            priority = 'P3_MEDIUM'
            color    = '#F1C40F'
        else:
            action   = 'ROUTINE_MONITORING'
            priority = 'P4_LOW'
            color    = '#27AE60'

        result = {
            'node_id':       sensor_data['node_id'],
            'estate':        sensor_data['estate'],
            'timestamp':     sensor_data['timestamp'],
            'pest_detected': pest_name,
            'severity':      severity,
            'confidence_pct': round(confidence, 1),
            'action':        action,
            'priority':      priority,
            'color':         color,
            'probabilities': {
                cls: round(float(p) * 100, 1)
                for cls, p in zip(
                    self.le.classes_, pest_prob)
            },
            'sensor_snapshot': {
                'temp':     sensor_data['temperature'],
                'humidity': sensor_data['humidity'],
                'rainfall': sensor_data.get(
                    'rainfall_mm', 0),
                'wind':     sensor_data['wind_speed']
            }
        }

        self.predictions.append(result)
        self.inference_count += 1
        return result


# ============================================
# STEP 7: Drone Dispatch System
#
# CONCEPT: ML prediction ke baad
# automatically drone dispatch!
#
# Priority Queue:
# P1 → Turant dispatch
# P2 → Agle 2 din
# P3 → Monitoring
# P4 → Kuch nahi
#
# Yahi "Precision Agriculture" hai!
# ============================================

class DroneDispatchSystem:
    """
    Automated drone dispatch based on ML alerts.
    Integrates with ACHAGA route optimizer.
    """

    def __init__(self):
        self.dispatch_queue = []
        self.completed      = []
        self.drone_fleet    = {
            'DRONE-01': {'status': 'STANDBY', 'battery': 100, 'location': 'Tocklai'},
            'DRONE-02': {'status': 'STANDBY', 'battery': 95,  'location': 'Tocklai'},
            'DRONE-03': {'status': 'STANDBY', 'battery': 87,  'location': 'Tocklai'},
        }

    def add_to_queue(self, prediction):
        """High severity predictions ko queue karo"""
        if prediction['priority'] in \
                ['P1_CRITICAL', 'P2_HIGH']:
            entry = {
                'estate':       prediction['estate'],
                'pest':         prediction['pest_detected'],
                'severity':     prediction['severity'],
                'priority':     prediction['priority'],
                'added_time':   prediction['timestamp'],
                'status':       'QUEUED'
            }
            self.dispatch_queue.append(entry)
            self.dispatch_queue.sort(
                key=lambda x: x['severity'],
                reverse=True)
            return True
        return False

    def dispatch_next(self):
        """Available drone ko dispatch karo"""
        available = [
            d for d, info in
            self.drone_fleet.items()
            if info['status'] == 'STANDBY'
            and info['battery'] > 20]

        if not available or \
                not self.dispatch_queue:
            return None

        drone    = available[0]
        mission  = self.dispatch_queue.pop(0)
        mission['status']       = 'DISPATCHED'
        mission['drone']        = drone
        mission['dispatch_time'] = \
            datetime.now().isoformat()

        self.drone_fleet[drone]['status'] = \
            'DEPLOYED'
        self.drone_fleet[drone]['location'] = \
            mission['estate']
        self.completed.append(mission)
        return mission


