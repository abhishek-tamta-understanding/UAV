#
# CONCEPT: Ek route = estates ka ek order
# [0,1,2,3,...,20] = Tocklai se shuru,
# har estate visit karo, wapas Tocklai
# ============================================

def route_distance(route, dist_matrix):
    """
    Ek route ki total distance nikalo.

    route = [0, 5, 3, 1, 8, ...]
            index numbers ka order

    Total = Estate1→2 + 2→3 + ... + last→start
    """
    total = 0
    n = len(route)
    for i in range(n):
        # Current estate se next estate
        from_idx = route[i]
        to_idx = route[(i+1) % n]
        total += dist_matrix[from_idx][to_idx]
    return total

