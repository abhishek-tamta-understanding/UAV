# ============================================

def greedy_route(start, dist_matrix, n):
    visited = [False]*n
    route = [start]
    visited[start] = True
    for _ in range(n-1):
        current = route[-1]
        nearest = min(
            [j for j in range(n)
             if not visited[j]],
            key=lambda j:
                dist_matrix[current][j])
        route.append(nearest)
        visited[nearest] = True
    return route

