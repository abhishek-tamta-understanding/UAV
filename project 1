def make_pest_label(T, H, R, F, M):
    helo  = (F in [2, 3]) * 3 + \
            (H > 75) * 2 + \
            (22 <= T <= 30) * 2 + \
            (R > 20) * 2 + random.randint(0, 2)
    thrip = (20 <= T <= 28) * 3 + \
            (50 <= H <= 75) * 2 + \
            (R < 15) * 2 + random.randint(0, 2)
    mite  = (T > 28) * 3 + \
            (H < 60) * 3 + \
            (R < 10) * 2 + random.randint(0, 2)
    loop  = (18 <= T <= 26) * 2 + \
            (F in [1, 2]) * 2 + random.randint(0, 3)
    scores = {'Helopeltis': helo, 'Thrips': thrip,
              'Mites': mite, 'Looper': loop}
    winner = max(scores, key=scores.get)
    sev    = min(10, max(0,
                         scores[winner] / 2 +
                         random.gauss(0, 0.5)))
    return winner, round(sev, 1)

pest_labels  = []
