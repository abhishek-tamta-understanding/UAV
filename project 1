# ============================================
# SIMULATED ANNEALING
#
# CONCEPT DETAIL:
#
# Socho ek ball hai pahad pe:
#
#    /\      /\
#   /  \    /  \    /\
#  /    \  /    \  /  \
# /      \/      \/    \___
#         ↑             ↑
#    Local min      Global min
#
# Normal GA: Ball local min mein
#            fas jaati hai
#
# SA trick: Kabhi kabhi ball ko
#           UPAR bhi jaane do!
#           (Temperature high hone pe)
#           Taaki global min mile!
#
# Probability formula:
# P = e^(-delta/T)
# delta = kitna bura hai new solution
# T = temperature
#
# T high → P high → buri route bhi lo
# T low  → P low  → sirf better lo
# ============================================

def simulated_annealing(
        initial_route,
        dist_matrix,
        T0=1000.0,      # Initial temperature
        T_end=0.001,    # Final temperature  
        alpha=0.995,    # Cooling rate
        iterations=100): # Per temperature
    """
    SA Algorithm — Paper Section 2.3.2
    
    initial_route: GA ka best route
                   (warm start!)
    T0:    Start temperature (hot)
    T_end: Stop temperature (cold)
    alpha: Kitni tezi se thanda hoga
           0.99 = slow cooling = better
           0.90 = fast cooling = quick
    """

    current_route = initial_route.copy()
    current_dist = route_distance(
        current_route, dist_matrix)

    best_route = current_route.copy()
    best_dist = current_dist

    T = T0
    history = []
    temp_history = []
    accepted_worse = 0  # SA ki khoobi track
    total_worse = 0

    print(f"  SA Starting temperature: {T0}")
    print(f"  SA Ending temperature:   {T_end}")
    print(f"  Cooling rate:            {alpha}")

    iteration_count = 0

    while T > T_end:
        for _ in range(iterations):

            # NEIGHBOR GENERATE KARO
            # Concept: 2 random estates
            # swap karo → new route banta hai
            new_route = current_route.copy()
            i = random.randint(1, n-2)
            j = random.randint(1, n-2)
            new_route[i], new_route[j] = \
                new_route[j], new_route[i]

            new_dist = route_distance(
                new_route, dist_matrix)

            # ACCEPT/REJECT DECISION
            # Concept: Metropolis Criterion
            delta = new_dist - current_dist

            if delta < 0:
                # Better route → hamesha accept!
                current_route = new_route
                current_dist = new_dist
            else:
                # Worse route →
                # kabhi kabhi accept karo!
                # Probability = e^(-delta/T)
                # T high → high probability
                # T low  → low probability
                total_worse += 1
                probability = math.exp(
                    -delta / T)
                if random.random() < probability:
                    current_route = new_route
                    current_dist = new_dist
                    accepted_worse += 1
                    # ↑ Yahi SA ki MAGIC hai!
                    # Worse solution accept ki
                    # Local optima se bahar!

            # Global best track karo
            if current_dist < best_dist:
                best_dist = current_dist
                best_route = current_route.copy()

        # Temperature cool karo
        # Paper ka adaptive cooling!
        T *= alpha
        iteration_count += 1
        history.append(best_dist)
        temp_history.append(T)

    # SA statistics
    if total_worse > 0:
        acceptance_rate = \
            accepted_worse/total_worse*100
    else:
        acceptance_rate = 0

    print(f"  Total temperature steps: "
          f"{iteration_count}")
    print(f"  Worse solutions tried:   "
          f"{total_worse}")
    print(f"  Worse solutions accepted:"
          f" {accepted_worse} "
          f"({acceptance_rate:.1f}%)")

    return best_route, best_dist, \
           history, temp_history

