def gps_to_meters(lon, lat,
                  lon0=94.0, lat0=26.5):
    R = 6371000
    x = R * math.radians(
        lon-lon0) * math.cos(
        math.radians(lat0))
    y = R * math.radians(lat-lat0)
    return x, y

