def genetic_algorithm(
        dist_matrix, n_estates,
        pop_size=50,
        generations=200,
        mutation_rate=0.02):

    indices = list(range(1, n_estates+1))
    population = [
        [0] + random.sample(
            indices, len(indices))
        for _ in range(pop_size)
    ]

    best_route = None
    best_dist = float('inf')
    ga_history = []

    for gen in range(generations):
        fitness = []
        for route in population:
            d = route_distance(
                route, dist_matrix)
            fitness.append(1.0/d)
            if d < best_dist:
                best_dist = d
                best_route = route.copy()

        ga_history.append(best_dist)
        total_fit = sum(fitness)
        probs = [f/total_fit for f in fitness]

        sorted_pop = sorted(
            zip(fitness, population),
            reverse=True)
        new_pop = [r for _, r
                   in sorted_pop[:2]]

        while len(new_pop) < pop_size:
            p1 = population[
                np.random.choice(
                    len(population), p=probs)]
            p2 = population[
                np.random.choice(
                    len(population), p=probs)]

            size = len(p1)
            seg1 = p1[1:]
            seg2 = p2[1:]
            s = random.randint(0, len(seg1)-2)
            e = random.randint(s+1, len(seg1)-1)

            child = [None]*len(seg1)
            child[s:e] = seg1[s:e]
            remaining = [x for x in seg2
                        if x not in child]
            j = 0
            for i in range(len(child)):
                if child[i] is None:
                    child[i] = remaining[j]
                    j += 1

            child = [0] + child
            if random.random() < mutation_rate:
                i = random.randint(1, size-2)
                j = random.randint(1, size-2)
                child[i], child[j] = \
                    child[j], child[i]

            new_pop.append(child)
        population = new_pop

    return best_route, best_dist, ga_history

