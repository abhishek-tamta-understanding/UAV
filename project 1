# ============================================
# STEP 1: Dataset Banao
#
# CONCEPT: Real Tocklai data hota toh
# best tha. Abhi synthetic data banate
# hain — real patterns ke saath!
#
# Data based on:
# - Tocklai research publications
# - Tea pest biology
# - Assam weather patterns
# ============================================

np.random.seed(42)
n_samples = 2000  # 2000 observations

print("="*50)
print("PEST PREDICTION DATASET:")
print("="*50)
print("Generating realistic Assam")
print("tea garden data...")

# ----------------------------------------
# FEATURES BANAO (Input variables)
# ----------------------------------------

# 1. Month (1-12)
# Assam mein pest seasonality strong hai
months = np.random.randint(1, 13, n_samples)

# 2. Temperature (°C)
# Assam: 15-35°C range
# Season-dependent!
temp_base = 25 + 8*np.sin(
    (months - 3) * np.pi/6)
temperature = temp_base + np.random.normal(
    0, 2, n_samples)
temperature = np.clip(temperature, 15, 38)

# 3. Relative Humidity (%)
# Assam monsoon: June-Sept high humidity
humidity_base = 70 + 15*np.sin(
    (months - 6) * np.pi/6)
humidity = humidity_base + \
    np.random.normal(0, 5, n_samples)
humidity = np.clip(humidity, 40, 98)

# 4. Rainfall last 7 days (mm)
# Monsoon months mein zyada
rain_base = np.where(
    (months >= 6) & (months <= 9),
    50, 10)
rainfall_7d = np.random.exponential(
    rain_base, n_samples)
rainfall_7d = np.clip(rainfall_7d, 0, 200)

# 5. Flush stage
# 0=dormant, 1=banjhi, 2=young flush
# 3=mature flush, 4=hardened
flush_stage = np.random.choice(
    [0, 1, 2, 3, 4],
    n_samples,
    p=[0.1, 0.15, 0.3, 0.3, 0.15])

# 6. Previous week pest count
# (Field survey data)
prev_pest_count = np.random.poisson(
    3, n_samples)

# 7. Days since last spray
days_since_spray = np.random.randint(
    0, 21, n_samples)

# 8. Estate elevation (meters)
# Assam tea: 50-800m
elevation = np.random.normal(
    150, 80, n_samples)
elevation = np.clip(elevation, 50, 800)

# 9. Wind speed (km/h)
wind_speed = np.random.exponential(
    8, n_samples)
wind_speed = np.clip(wind_speed, 0, 30)

# ----------------------------------------
# TARGET VARIABLES BANAO
# Based on real pest biology!
# ----------------------------------------

pest_type = []      # Konsa pest?
severity_score = [] # Kitna severe? (0-10)

for i in range(n_samples):
    T = temperature[i]
    H = humidity[i]
    R = rainfall_7d[i]
    F = flush_stage[i]
    M = months[i]
    P = prev_pest_count[i]
    D = days_since_spray[i]

    # ====================================
    # PEST BIOLOGY RULES
    # (Tocklai research se!)
    # ====================================

    # HELOPELTIS CONDITIONS:
    # - Young flush (stage 2-3)
    # - High humidity (>75%)
    # - Temperature 22-30°C
    # - Post-rain (flush emergence)
    helopeltis_score = 0
    if F in [2, 3]:
        helopeltis_score += 3
    if H > 75:
        helopeltis_score += 2
    if 22 <= T <= 30:
        helopeltis_score += 2
    if R > 20:
        helopeltis_score += 2
    if M in [4, 5, 8, 9]:
        helopeltis_score += 1  # Peak months

    # THRIPS CONDITIONS:
    # - Warm temp (20-28°C)
    # - Moderate humidity (50-75%)
    # - Young-mature flush
    thrips_score = 0
    if 20 <= T <= 28:
        thrips_score += 3
    if 50 <= H <= 75:
        thrips_score += 2
    if F in [2, 3, 4]:
        thrips_score += 2
    if R < 15:
        thrips_score += 2  # Dry conditions
    if M in [3, 4, 5, 10, 11]:
        thrips_score += 1

    # MITES CONDITIONS:
    # - Hot dry weather
    # - Low humidity (<60%)
    # - Mature/hardened leaves
    mites_score = 0
    if T > 28:
        mites_score += 3
    if H < 60:
        mites_score += 3
    if F in [3, 4]:
        mites_score += 2
    if R < 10:
        mites_score += 2  # Drought stress
    if M in [3, 4, 11, 12]:
        mites_score += 1

    # LOOPER CONDITIONS:
    # - Moderate temperature
    # - Any flush stage
    # - More random/less weather dependent
    looper_score = 0
    if 18 <= T <= 26:
        looper_score += 2
    if F in [1, 2]:
        looper_score += 2
    if M in [6, 7, 8]:
        looper_score += 2
    looper_score += np.random.randint(0, 3)

    # WINNER pest decide karo
    scores = {
        'Helopeltis': helopeltis_score,
        'Thrips':     thrips_score,
        'Mites':      mites_score,
        'Looper':     looper_score
    }

    # Noise add karo (nature unpredictable!)
    for pest in scores:
        scores[pest] += np.random.randint(
            0, 3)

    winner = max(scores, key=scores.get)
    max_score = scores[winner]

    # Previous attack bhi influence karta
    if P > 5:
        max_score += 2
    if D > 14:
        max_score += 1

    # Severity normalize karo (0-10)
    severity = min(10,
                   max_score / 2 +
                   np.random.normal(0, 0.5))
    severity = max(0, severity)

    pest_type.append(winner)
    severity_score.append(round(severity, 1))

